                                            "type": "item",
                                            "id": "e0989328-9823-47ab-a1d7-fcdfb0aeb8dd",
                                            "data": {
                                                "type": "text",
                                                "stretch": true,
                                                "fillArea": false,
                                                "textSize": 1,
                                                "textBackground": "none",
                                                "placeholderInvisible": false,
                                                "placeholderStretch": true,
