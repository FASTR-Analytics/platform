#!/bin/bash

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
cd "$SCRIPT_DIR"

VERSION="$1"
CUSTOM_BASE="$2"
if [ -z "$VERSION" ]; then
    echo "Usage: generate-changelog <version> [base-commit]"
    exit 1
fi

ADMIN_WEBSITE_URL="${ADMIN_WEBSITE_URL:-https://status-api.fastr-analytics.org}"
STATUS_API_KEY="${STATUS_API_KEY:?STATUS_API_KEY is required}"
TODAY=$(date +%Y-%m-%d)

echo "Generating changelog entry for v$VERSION ($TODAY)..."

# Diff base: use explicit base commit if provided, otherwise auto-detect
if [ -n "$CUSTOM_BASE" ]; then
    BASE_COMMIT=$(git rev-parse "$CUSTOM_BASE" 2>/dev/null || true)
    if [ -z "$BASE_COMMIT" ]; then
        echo "Error: Could not resolve base commit '$CUSTOM_BASE'"
        exit 1
    fi
    echo "Using custom base: $CUSTOM_BASE ($BASE_COMMIT)"
else
    # If HEAD is itself a "Deploy version" commit (standalone run after deploy), use the previous one
    HEAD_MSG=$(git log --format="%s" -1 2>/dev/null || true)
    if echo "$HEAD_MSG" | grep -q "^Deploy version"; then
        BASE_COMMIT=$(git log --format="%H" --grep="^Deploy version" -2 2>/dev/null | tail -1 || true)
    else
        BASE_COMMIT=$(git log --format="%H" --grep="^Deploy version" -1 2>/dev/null || true)
    fi

    if [ -z "$BASE_COMMIT" ]; then
        BASE_COMMIT=$(git log --format="%H" | tail -1)
        echo "No previous release commit found — diffing from initial commit."
    fi
fi

# Diff TypeScript source only (server, client/src, lib — skip generated/build files)
# Combines committed changes since BASE_COMMIT and any staged/unstaged changes on top of HEAD
DIFF=$(
    git diff "${BASE_COMMIT}..HEAD" -- \
        'server/**/*.ts' 'client/src/**/*.tsx' 'client/src/**/*.ts' 'lib/**/*.ts' \
        ':!deno.lock' ':!lib/translate/ui_strings.ts' \
        2>/dev/null
    git diff HEAD -- \
        'server/**/*.ts' 'client/src/**/*.tsx' 'client/src/**/*.ts' 'lib/**/*.ts' \
        ':!deno.lock' ':!lib/translate/ui_strings.ts' \
        2>/dev/null
) || true

if [ -z "$DIFF" ]; then
    echo "No source changes since last release. Skipping changelog update."
    exit 0
fi

# Fetch existing changelogs from Admin Website for context
EXISTING_CHANGELOG=$(curl -sf "$ADMIN_WEBSITE_URL/api/changelog" || true)
EXISTING_CHANGELOG_ADMIN=$(curl -sf -H "Authorization: Bearer $STATUS_API_KEY" "$ADMIN_WEBSITE_URL/api/changelog/superadmin" || true)

# Check if this version already has an entry (re-deploy without version bump)
VERSION_EXISTS=false
if echo "$EXISTING_CHANGELOG" | grep -q "^\#\# \[$VERSION\]"; then
    VERSION_EXISTS=true
    echo "Existing user changelog entry found for v$VERSION — will update it."
fi
VERSION_ADMIN_EXISTS=false
if echo "$EXISTING_CHANGELOG_ADMIN" | grep -q "^\#\# \[$VERSION\]"; then
    VERSION_ADMIN_EXISTS=true
    echo "Existing admin changelog entry found for v$VERSION — will update it."
fi

# Cap at ~150KB to keep token usage reasonable
DIFF_TRIMMED=$(echo "$DIFF" | head -c 150000)

if [ "$VERSION_EXISTS" = "true" ]; then
    ENTRY=$(claude -p "You are updating an existing user-facing changelog entry for a data analytics web platform called FASTR Analytics. It is used by health data teams to manage, analyze, and visualize health system data (HMIS, HFA surveys, etc.).

Version: $VERSION
Date: $TODAY

## Existing changelog (the current entry for this version is in here):
\`\`\`
${EXISTING_CHANGELOG:-"(no existing entries)"}
\`\`\`

## Additional source code changes since the entry was last generated:
\`\`\`diff
$DIFF_TRIMMED
\`\`\`

Produce a single updated changelog entry that merges the existing entry for [$VERSION] with any new user-facing changes from the diff. Output the complete updated entry in this exact format:

## [$VERSION] - $TODAY

### Added
- (new features users can access)

### Changed
- (improvements to existing features)

### Fixed
- (bugs that are now fixed)

Rules:
- The \"user\" is a health data analyst using the web app — someone who uploads data, runs analysis modules, creates visualizations, and exports reports
- Only include changes that directly affect what this user sees or can do in the application
- Skip anything related to: admin/ops tooling, email notifications, internal logging, deployment scripts, server monitoring, backend infrastructure, API internals, or developer-facing changes
- Be specific and concise (one line per bullet)
- Omit section headers (Added/Changed/Fixed) that have no items
- Do NOT duplicate bullets already in the existing entry
- If the diff adds nothing new, output the existing entry unchanged
- Do NOT include any explanation outside the format
- Maximum 8 bullet points total" 2>/dev/null)
else
    ENTRY=$(claude -p "You are writing a user-facing changelog entry for a data analytics web platform called FASTR Analytics. It is used by health data teams to manage, analyze, and visualize health system data (HMIS, HFA surveys, etc.).

New version: $VERSION
Date: $TODAY

## Existing changelog (for context and consistency):
\`\`\`
${EXISTING_CHANGELOG:-"(no existing entries)"}
\`\`\`

## Source code diff (all changes since the last release):
\`\`\`diff
$DIFF_TRIMMED
\`\`\`

Write a changelog entry in this exact Keep-a-Changelog format:

## [$VERSION] - $TODAY

### Added
- (new features users can access)

### Changed
- (improvements to existing features)

### Fixed
- (bugs that are now fixed)

Rules:
- The \"user\" is a health data analyst using the web app — someone who uploads data, runs analysis modules, creates visualizations, and exports reports
- Only include changes that directly affect what this user sees or can do in the application
- Skip anything related to: admin/ops tooling, email notifications, internal logging, deployment scripts, server monitoring, backend infrastructure, API internals, or developer-facing changes
- Be specific and concise (one line per bullet)
- Omit section headers (Added/Changed/Fixed) that have no items
- If there are no meaningful user-facing changes, output exactly: SKIP
- Do NOT include any explanation outside the format
- Maximum 8 bullet points total" 2>/dev/null)
fi

if [ -z "$ENTRY" ] || [ "$ENTRY" = "SKIP" ]; then
    echo "No meaningful user-facing changes. Skipping user changelog update."
else
    if ! echo "$ENTRY" | grep -q "^\#\# \[$VERSION\]"; then
        echo "Warning: Claude output did not match expected format. Skipping user changelog."
        echo "--- Claude output: ---"
        echo "$ENTRY"
    else
        PAYLOAD=$(printf '{"version":"%s","entry":%s}' "$VERSION" "$(echo "$ENTRY" | python3 -c "import json,sys; print(json.dumps(sys.stdin.read()))")")
        if [ "$VERSION_EXISTS" = "true" ]; then
            curl -sf -X PUT "$ADMIN_WEBSITE_URL/api/changelog/entry" \
                -H "Authorization: Bearer $STATUS_API_KEY" \
                -H "Content-Type: application/json" \
                -d "$PAYLOAD" || echo "Failed to update user changelog entry."
        else
            curl -sf -X POST "$ADMIN_WEBSITE_URL/api/changelog/entry" \
                -H "Authorization: Bearer $STATUS_API_KEY" \
                -H "Content-Type: application/json" \
                -d "$PAYLOAD" || echo "Failed to post user changelog entry."
        fi
        echo "User changelog updated for v$VERSION."
    fi
fi

echo "Generating super-admin changelog entry for v$VERSION..."

if [ "$VERSION_ADMIN_EXISTS" = "true" ]; then
    ADMIN_ENTRY=$(claude -p "You are updating an existing technical changelog entry for the FASTR Analytics platform. This is for super-admins and developers.

Version: $VERSION
Date: $TODAY

## Existing super-admin changelog (the current entry for this version is in here):
\`\`\`
${EXISTING_CHANGELOG_ADMIN:-"(no existing entries)"}
\`\`\`

## Additional source code changes since the entry was last generated:
\`\`\`diff
$DIFF_TRIMMED
\`\`\`

Produce a single updated changelog entry that merges the existing entry for [$VERSION] with any new changes from the diff. Output the complete updated entry in this exact format:

## [$VERSION] - $TODAY

### Added
- (new features or endpoints)

### Changed
- (modifications to existing behaviour, APIs, data structures)

### Fixed
- (bug fixes)

### Internal
- (refactoring, logging, infra, deployment, tooling changes)

Rules:
- Include ALL changes — user-facing, backend, API, database, infrastructure, tooling
- Be specific and technical (mention route names, table names, component names where relevant)
- Omit section headers that have no items
- Do NOT duplicate bullets already in the existing entry
- If the diff adds nothing new, output the existing entry unchanged
- Do NOT include any explanation outside the format
- No maximum bullet point limit — include everything noteworthy" 2>/dev/null)
else
    ADMIN_ENTRY=$(claude -p "You are writing a technical changelog entry for the FASTR Analytics platform. This is for super-admins and developers — it should capture everything that changed, including backend, infrastructure, API, and internal changes.

New version: $VERSION
Date: $TODAY

## Existing super-admin changelog (for context and consistency):
\`\`\`
${EXISTING_CHANGELOG_ADMIN:-"(no existing entries)"}
\`\`\`

## Source code diff (all changes since the last release):
\`\`\`diff
$DIFF_TRIMMED
\`\`\`

Write a changelog entry in this exact Keep-a-Changelog format:

## [$VERSION] - $TODAY

### Added
- (new features or endpoints)

### Changed
- (modifications to existing behaviour, APIs, data structures)

### Fixed
- (bug fixes)

### Internal
- (refactoring, logging, infra, deployment, tooling changes)

Rules:
- Include ALL changes — user-facing, backend, API, database, infrastructure, tooling
- Be specific and technical (mention route names, table names, component names where relevant)
- Omit section headers that have no items
- Do NOT include any explanation outside the format
- No maximum bullet point limit — include everything noteworthy" 2>/dev/null)
fi

if [ -z "$ADMIN_ENTRY" ] || [ "$ADMIN_ENTRY" = "SKIP" ]; then
    echo "No admin changelog entry generated."
elif ! echo "$ADMIN_ENTRY" | grep -q "^\#\# \[$VERSION\]"; then
    echo "Warning: Claude admin output did not match expected format. Skipping."
    echo "--- Claude output: ---"
    echo "$ADMIN_ENTRY"
else
    ADMIN_PAYLOAD=$(printf '{"version":"%s","entry":%s}' "$VERSION" "$(echo "$ADMIN_ENTRY" | python3 -c "import json,sys; print(json.dumps(sys.stdin.read()))")")
    if [ "$VERSION_ADMIN_EXISTS" = "true" ]; then
        curl -sf -X PUT "$ADMIN_WEBSITE_URL/api/changelog/superadmin/entry" \
            -H "Authorization: Bearer $STATUS_API_KEY" \
            -H "Content-Type: application/json" \
            -d "$ADMIN_PAYLOAD" || echo "Failed to update super-admin changelog entry."
    else
        curl -sf -X POST "$ADMIN_WEBSITE_URL/api/changelog/superadmin/entry" \
            -H "Authorization: Bearer $STATUS_API_KEY" \
            -H "Content-Type: application/json" \
            -d "$ADMIN_PAYLOAD" || echo "Failed to post super-admin changelog entry."
    fi
    echo "Super-admin changelog updated for v$VERSION."
fi
