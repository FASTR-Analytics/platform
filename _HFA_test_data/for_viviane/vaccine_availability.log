. 
. *--- Weights ----------------------------------------------------------
. import delimited "weights.csv", varnames(1) clear
(4 vars, 363 obs)

. keep id_fac_txt wgt

. drop if missing(id_fac_txt)
(1 observation deleted)

. tempfile weights

. save `weights'
file /var/folders/83/r22l0yrs5djfwz884fz8vtj40000gn/T//St63855.000001 saved
    as .dta format

. 
. *--- Survey data ------------------------------------------------------
. import delimited "data_raw.csv", varnames(1) clear
(195 vars, 849 obs)

. keep id_fac_txt sup_05aaa_a sup_05aaa_b sup_05aaa_c ///
>     sup_05aaa_d sup_05aaa_e sup_05aaa_f

. drop if missing(id_fac_txt)
(0 observations deleted)

. 
. * One row per facility: keep the first submission in file order (what
. * the platform does). To keep the last instead, change 1 to _N.
. gen long row_in_file = _n

. bysort id_fac_txt (row_in_file): keep if _n == 1
(395 observations deleted)

. sort row_in_file

. drop row_in_file

. 
. * Attach weights; facilities without a weight row get weight 1
. merge m:1 id_fac_txt using `weights', keep(master match) nogenerate

    Result                      Number of obs
    -----------------------------------------
    Not matched                            92
        from master                        92  
        from using                          0  

    Matched                               362  
    -----------------------------------------

. gen double weight = cond(missing(wgt), 1, wgt)

. 
. *--- Indicators: vaccine available today at the facility --------------
. * Each line recodes one survey question to a 0/1 indicator: Yes (1) -> 1,
. * No (2) -> 0, Don't know (-99) -> `dk_value', blank -> missing.
. gen vac_measles = cond(missing(sup_05aaa_a), ., cond(sup_05aaa_a == -99, `dk_
> value', sup_05aaa_a == 1))   // ind160
(242 missing values generated)

. gen vac_penta   = cond(missing(sup_05aaa_b), ., cond(sup_05aaa_b == -99, `dk_
> value', sup_05aaa_b == 1))   // ind166
(241 missing values generated)

. gen vac_bcg     = cond(missing(sup_05aaa_c), ., cond(sup_05aaa_c == -99, `dk_
> value', sup_05aaa_c == 1))   // ind172
(241 missing values generated)

. gen vac_polio   = cond(missing(sup_05aaa_d), ., cond(sup_05aaa_d == -99, `dk_
> value', sup_05aaa_d == 1))   // ind178
(241 missing values generated)

. gen vac_pcv     = cond(missing(sup_05aaa_e), ., cond(sup_05aaa_e == -99, `dk_
> value', sup_05aaa_e == 1))   // ind184
(241 missing values generated)

. gen vac_hpv     = cond(missing(sup_05aaa_f), ., cond(sup_05aaa_f == -99, `dk_
> value', sup_05aaa_f == 1))   // ind190
(241 missing values generated)

. 
. * Index: share of the six tracer vaccines available;
. * missing if any component is missing                                        
>                              // ind274
. gen vac_index = (vac_measles + vac_penta + vac_bcg + vac_polio + vac_pcv + va
> c_hpv) / 6
(242 missing values generated)

. 
. *--- Results: national, all facility types ----------------------------
