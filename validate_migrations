#!/bin/bash

set -e

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
CONTAINER_NAME="wb-fastr-migration-test-$$"
DB_PORT=54329
DB_USER="postgres"
DB_PASS="testpass"

cleanup() {
    echo "Cleaning up..."
    docker stop "$CONTAINER_NAME" 2>/dev/null || true
    docker rm "$CONTAINER_NAME" 2>/dev/null || true
    rm -f /tmp/schema_before_$$.sql /tmp/schema_after_$$.sql
}

trap cleanup EXIT

echo "Starting temporary postgres container..."
docker run -d \
    --name "$CONTAINER_NAME" \
    -e POSTGRES_PASSWORD="$DB_PASS" \
    -p "$DB_PORT:5432" \
    postgres:15 > /dev/null

echo "Waiting for postgres to be ready..."
for i in {1..30}; do
    if docker exec "$CONTAINER_NAME" pg_isready -U "$DB_USER" > /dev/null 2>&1; then
        break
    fi
    sleep 0.5
done

fail() {
    echo ""
    echo -e "\033[91m╔══════════════════════════════════════════════════════════════╗"
    echo "║              MIGRATION VALIDATION FAILED                     ║"
    echo "║                                                              ║"
    printf "║  %-60s║\n" "$1"
    echo "╚══════════════════════════════════════════════════════════════╝\033[0m"
}

validate() {
    local label="$1"
    local db_name="$2"
    local base_schema="$3"
    local migration_dir="$4"

    local psql="docker exec -i $CONTAINER_NAME psql -U $DB_USER -d $db_name -v ON_ERROR_STOP=1"
    local pg_dump="docker exec $CONTAINER_NAME pg_dump -U $DB_USER -d $db_name --schema-only --no-owner --no-privileges"

    echo ""
    echo "=== Validating $label migrations ==="

    docker exec "$CONTAINER_NAME" psql -U "$DB_USER" -c "CREATE DATABASE $db_name" > /dev/null

    echo "Running base schema ($(basename "$base_schema"))..."
    cat "$base_schema" | $psql -q

    echo "Capturing schema snapshot (before migrations)..."
    $pg_dump | grep -v "^--" | grep -v "^$" | grep -v "^\\\\restrict" | grep -v "^\\\\unrestrict" | sort > /tmp/schema_before_$$.sql

    echo "Running migrations..."
    local count=0

    for f in "$migration_dir"/*.sql; do
        if [[ "$(basename "$f")" == _* ]]; then
            continue
        fi

        local filename=$(basename "$f")
        echo "  Applying: $filename"

        if ! cat "$f" | $psql -q 2>&1; then
            echo "  FAILED: $filename"
            fail "A $label migration crashed. See error above."
            exit 1
        fi

        count=$((count + 1))
    done

    echo "Capturing schema snapshot (after migrations)..."
    $pg_dump | grep -v "^--" | grep -v "^$" | grep -v "^\\\\restrict" | grep -v "^\\\\unrestrict" | sort > /tmp/schema_after_$$.sql

    echo "Comparing schemas..."
    if ! diff -q /tmp/schema_before_$$.sql /tmp/schema_after_$$.sql > /dev/null 2>&1; then
        fail "$label schema changed on fresh DB: not idempotent."
        echo ""
        echo "Diff (before vs after):"
        diff /tmp/schema_before_$$.sql /tmp/schema_after_$$.sql || true
        exit 1
    fi

    echo "$label: $count migrations ran successfully, schema unchanged"
}

validate "instance" "migration_test_instance" \
    "$SCRIPT_DIR/server/db/instance/_main_database.sql" \
    "$SCRIPT_DIR/server/db/migrations/instance"

validate "project" "migration_test_project" \
    "$SCRIPT_DIR/server/db/project/_project_database.sql" \
    "$SCRIPT_DIR/server/db/migrations/project"

echo ""
echo -e "\033[92m╔══════════════════════════════════════════════════════════════╗"
echo "║              MIGRATION VALIDATION PASSED                     ║"
echo "║                                                              ║"
echo "║  Instance + project migrations ran successfully              ║"
echo "║  Schemas unchanged (all migrations idempotent)               ║"
echo "╚══════════════════════════════════════════════════════════════╝\033[0m"
